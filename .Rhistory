# 1. load the necessary library
library(tidyquant)
library(tidyverse)
library(keras)
# 2. Pull data directly
df <- tq_get("NVDA", from = "2021-01-01", to = Sys.Date()) %>%
select(date, close) %>%
drop_na()
View(df)
# 3. Scaling
min_val <- min(df$close); max_val <- max(df$close)
scaled_data <- (df$close - min_val) / (max_val - min_val)
# 4. Create Windows (30 days)
window_size <- 30
x_list <- list(); y_list <- list()
for(i in 1:(length(scaled_data) - window_size)) {
x_list[[i]] <- scaled_data[i:(i + window_size - 1)]
y_list[[i]] <- scaled_data[i + window_size]
}
x_data <- array(unlist(x_list), dim = c(length(x_list), window_size, 1))
y_data <- unlist(y_list)
# 5. Split and Train (LSTM)
split <- floor(0.8 * nrow(x_data))
x_train <- x_data[1:split,,]; y_train <- y_data[1:split]
x_test <- x_data[(split+1):nrow(x_data),,]; y_test <- y_data[(split+1):nrow(x_data)]
# Define Model
model_lstm <- keras_model_sequential() %>%
layer_lstm(units = 50, input_shape = c(window_size, 1)) %>%
layer_dense(units = 1) %>%
compile(optimizer = "adam", loss = "mse")
