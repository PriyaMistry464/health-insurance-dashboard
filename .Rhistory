install.packages("statmod")
install.packages("tweedie")
library(statmod) # For Tweedie modeling
library(tweedie)
library(statmod) # For Tweedie modeling
library(tweedie)
View(clean_data)
View(clean_data)
# 1. Fit the Tweedie GLM
#using 'risk_cluster' as a predictor because just proved it's significant
pricing_model <- glm(claimcst0 ~ risk_cluster + veh_value + agecat + gender + area,
data = clean_data,
family = tweedie(var.power = 1.5, link.power = 0))
View(pricing_model)
# 2. View the results
summary(pricing_model)
# 3. Add predicted "Fair Premium" to dataset
clean_data$predicted_premium <- predict(pricing_model, type = "response")
View(clean_data)
# 4. Check the "Lift" - are predictions matching actuals?
# Compare the top 10% predicted risks vs their actual average costs
clean_data %>%
mutate(decile = ntile(predicted_premium, 10)) %>%
group_by(decile) %>%
summarise(actual_avg_cost = mean(claimcst0),
predicted_avg_premium = mean(predicted_premium))
#total portfolio losses
set.seed(42)
n_simulations <- 10000
total_portfolio_losses <- numeric(n_simulations)
#using the predicted premiums as'expected' mean for the simulation
# For each simulation, draw from the Tweedie distribution for the whole portfolio
for (i in 1:n_simulations) {
simulated_total = sum(rtweedie(nrow(clean_data),
mu = clean_data$predicted_premium,
phi = 648.3, # This is the dispersion from your summary
p = 1.5))
total_portfolio_losses[i] <- simulated_total
}
#Calculate the Portfolio Mean
portfolio_mu <- sum(clean_data$predicted_premium)
#Estimate the Portfolio Variance
# For Tweedie: Var = phi * mu^p.
# For the sum of the portfolio, aggregate the variance:
portfolio_var <- sum(648.3 * (clean_data$predicted_premium^1.5))
portfolio_sd <- sqrt(portfolio_var)
# Use a Normal Approximation
set.seed(42)
total_portfolio_losses <- rnorm(n_simulations, mean = portfolio_mu, sd = portfolio_sd)
# 4. Calculate your 99% VaR
VaR_99 <- quantile(total_portfolio_losses, 0.99)
# 5. Plot the results
hist(total_portfolio_losses, breaks = 50, col = "skyblue",
main = "Portfolio Loss Distribution (Simulated)",
xlab = "Total Annual Claims ($)")
abline(v = VaR_99, col = "red", lwd = 2, lty = 2)
text(VaR_99, 100, paste("99% VaR:", round(VaR_99)), pos = 4, col = "red")
print(TVaR_99)
TVaR_99 <- mean(total_portfolio_losses[total_portfolio_losses > VaR_99])
print(TVaR_99)
