# 3. Build the Random Forest Model
rf_model <- randomForest(
as.factor(fraud) ~ distance_from_home + distance_from_last_transaction +
ratio_to_median_purchase_price + repeat_retailer +
used_chip + used_pin_number + online_order,
data = train_set,
ntree = 150,
mtry = 4,
maxnodes = 30
)
# 4. Display Variable Importance
cat("--- Variable Importance (Node Purity) ---\n")
importance_stats <- importance(rf_model, type = 2)
print(importance_stats)
# 5. Model Prediction
# Ensure actual values are factors for the confusion matrix
actual_values <- as.factor(test_set$fraud)
predicted_values <- predict(rf_model, newdata = test_set)
# 6. Calculate Precision, Recall, and F1
library(caret)
cm <- confusionMatrix(predicted_values, actual_values, positive = "1")
# Extract the specific metrics
precision_val <- cm$byClass["Precision"]
recall_val    <- cm$byClass["Recall"]
f1_val        <- cm$byClass["F1"]
overall_acc   <- cm$overall["Accuracy"]
# 7. Create Performance Table
performance_report <- data.frame(
Metric = c("Accuracy", "Precision (Fraud)", "Recall (Fraud)", "F1-Score"),
Value = c(overall_acc, precision_val, recall_val, f1_val)
)
cat("\n--- Prediction Performance Report ---\n")
print(performance_report, row.names = FALSE)
