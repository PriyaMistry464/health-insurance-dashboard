),
F1_Score = c(
cm$overall['Accuracy'],
mean(stats[, "F1"], na.rm = TRUE),
sum(stats[, "F1"] * weights, na.rm = TRUE)
)
)
return(results)
}
# 5. Execute and Print
results_log <- get_all_metrics(nn_log, X_scaled_mat, Y_factor)
results_tan <- get_all_metrics(nn_tan, X_scaled_mat, Y_factor)
cat("\n--- Logistic Activation Measures ---\n")
print(results_log)
cat("\n--- Tanh Activation Measures ---\n")
print(results_tan)
# 1. Load necessary libraries
library(e1071)
library(caret)
# 2. Load the data
data <- read.csv("C:/Users/priya/OneDrive/Documents/STAT 574/hw1STAT574S26/DATA SETS/concussions_data.csv")
# 3. define and order the levels of the target variable
target_levels <- c("mild", "moderate", "severe")
data$concussion <- factor(data$concussion, levels = target_levels)
# 4. Fit the Naïve Bayes Model
nb_model <- naiveBayes(concussion ~ ., data = data)
# 5. Make Predictions
predictions <- predict(nb_model, data)
predictions <- factor(predictions, levels = target_levels)
# 6. Generate Confusion Matrix and Statistics
results <- confusionMatrix(predictions, data$concussion)
metrics_per_class <- results$byClass
# 7. Helper Function to compute averages
calculate_metrics <- function(metric_name) {
# Per-class scores
scores <- metrics_per_class[, metric_name]
# Weights based on class frequency (Support)
support <- as.numeric(table(data$concussion))
weights <- support / sum(support)
# Calculations
macro <- mean(scores, na.rm = TRUE)
weighted <- sum(scores * weights, na.rm = TRUE)
return(c(Macro = macro, Weighted = weighted))
}
# 8. Compute all requested measures
micro_val <- results$overall['Accuracy']
p_avg <- calculate_metrics("Precision")
r_avg <- calculate_metrics("Recall")
f1_avg <- calculate_metrics("F1")
# 9. Final Output Table
performance_summary <- data.frame(
Measure = c("Precision", "Recall", "F1-Score"),
Micro = rep(micro_val, 3),
Macro = c(p_avg["Macro"], r_avg["Macro"], f1_avg["Macro"]),
Weighted_Macro = c(p_avg["Weighted"], r_avg["Weighted"], f1_avg["Weighted"])
)
cat("\n--- FULL PERFORMANCE MEASURES ---\n")
print(round(performance_summary[,-1], 4), row.names = performance_summary$Measure)
# 1. Load the library
library(randomForest)
# 2. Import the dataset
hospital_df <- read.csv("C:/Users/priya/OneDrive/Documents/STAT 574/hw1STAT574S26/DATA SETS/hospital_data.csv")
# 3. Data Pre-processing: Convert gender to a numeric dummy variable
hospital_df$gender <- ifelse(hospital_df$gender == "M", 0, 1)
# 4. Partition the data into Training (80%) and Testing (20%)
set.seed(902881)
obs_count <- nrow(hospital_df)
pick_train <- sample(c(TRUE, FALSE), obs_count, replace = TRUE, prob = c(0.8, 0.2))
train_set <- hospital_df[pick_train, ]
test_set  <- hospital_df[!pick_train, ]
# 5. Fit the Random Forest Regression Model
rf_model <- randomForest(
surgery_cost ~ gender + age + BMI + ASA + surgery_duration_min,
data = train_set,
ntree = 100,
mtry = 4,
maxnodes = 50,
importance = TRUE
)
# 6. Display Variable Importance (Node Purity)
cat("--- Variable Importance Output ---\n")
importance_stats <- importance(rf_model, type = 2)
print(importance_stats)
# 7. Generate Predictions and Calculate Accuracy Metrics
preds <- predict(rf_model, newdata = test_set)
actuals <- test_set$surgery_cost
# Calculate the percentage of predictions within 10%, 15%, and 20% of actual values
acc_10 <- mean(abs(actuals - preds) < 0.10 * actuals)
acc_15 <- mean(abs(actuals - preds) < 0.15 * actuals)
acc_20 <- mean(abs(actuals - preds) < 0.20 * actuals)
# 8. Print Results
cat("\n--- Prediction Accuracy Metrics ---\n")
cat("Accuracy within 10%:", round(acc_10, 6), "\n")
cat("Accuracy within 15%:", round(acc_15, 6), "\n")
cat("Accuracy within 20%:", round(acc_20, 6), "\n")
# 7. Generate Predictions
preds <- predict(rf_model, newdata = test_set)
actuals <- test_set$surgery_cost
breaks <- quantile(actuals, probs = c(0, 0.33, 0.66, 1))
labels <- c("Low Cost", "Medium Cost", "High Cost")
actuals_cat <- cut(actuals, breaks = breaks, labels = labels, include.lowest = TRUE)
preds_cat   <- cut(preds,   breaks = breaks, labels = labels, include.lowest = TRUE)
# 8. Calculate Classification Performance Measures
library(caret)
# Create Confusion Matrix object which contains all the requested metrics
conf_matrix <- confusionMatrix(preds_cat, actuals_cat)
# 9. Display the Classification Report
cat("\n--- Performance Measures by Class ---\n")
print(conf_matrix$byClass[, c("Precision", "Recall", "F1")])
cat("\n--- Overall Averages ---\n")
# Calculate Macro and Weighted Averages manually to match your screenshot format
metrics_df <- as.data.frame(conf_matrix$byClass[, c("Precision", "Recall", "F1")])
macro_avg <- colMeans(metrics_df, na.rm = TRUE)
weighted_avg <- sapply(metrics_df, function(x) weighted.mean(x, table(actuals_cat)))
results_table <- rbind(Macro = macro_avg, Weighted = weighted_avg)
print(round(results_table, 4))
# 10. Accuracy within Tolerance
acc_10 <- mean(abs(actuals - preds) < 0.10 * actuals)
acc_15 <- mean(abs(actuals - preds) < 0.15 * actuals)
acc_20 <- mean(abs(actuals - preds) < 0.20 * actuals)
cat("\n--- Prediction Accuracy Metrics ---\n")
cat("Accuracy within 10%:", round(acc_10, 6), "\n")
cat("Accuracy within 15%:", round(acc_15, 6), "\n")
cat("Accuracy within 20%:", round(acc_20, 6), "\n")
