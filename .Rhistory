hospital_df <- read.csv("C:/Users/priya/OneDrive/Documents/STAT 574/hw1STAT574S26/DATA SETS/hospital_data.csv")
# 3. Data Pre-processing
hospital_df$gender <- ifelse(hospital_df$gender == "M", 0, 1)
# 4. Partition the data (80% Train, 20% Test)
set.seed(902881)
obs_count <- nrow(hospital_df)
pick_train <- sample(c(TRUE, FALSE), obs_count, replace = TRUE, prob = c(0.8, 0.2))
train_set <- hospital_df[pick_train, ]
test_set  <- hospital_df[!pick_train, ]
# 5. Fit the Random Forest Regression Model
rf_model <- randomForest(
surgery_cost ~ gender + age + BMI + ASA + surgery_duration_min,
data = train_set,
ntree = 100,
mtry = 4,
maxnodes = 50,
importance = TRUE
)
# 6. Display Variable Importance
cat("--- Variable Importance Output ---\n")
print(importance(rf_model, type = 2))
# 7. Generate Predictions
preds <- predict(rf_model, newdata = test_set)
actuals <- test_set$surgery_cost
# 8. Function to calculate Precision, Recall, and F1 for a given tolerance
get_metrics <- function(actual, predicted, tolerance) {
# Define 'Positive' as being within the % threshold of the true value
is_accurate <- abs(actual - predicted) <= (tolerance * actual)
target <- factor(rep(TRUE, length(actual)), levels = c(TRUE, FALSE))
predicted_check <- factor(is_accurate, levels = c(TRUE, FALSE))
cm <- confusionMatrix(predicted_check, target)
# Extract metrics
prec <- cm$byClass["Precision"]
rec  <- cm$byClass["Recall"]
f1   <- cm$byClass["F1"]
return(c(Precision = prec, Recall = rec, F1 = f1))
}
# 9. Compute Metrics for 10%, 15%, and 20%
metrics_10 <- get_metrics(actuals, preds, 0.10)
metrics_15 <- get_metrics(actuals, preds, 0.15)
metrics_20 <- get_metrics(actuals, preds, 0.20)
# 10. Final Performance Table
performance_report <- rbind(
"Within 10%" = metrics_10,
"Within 15%" = metrics_15,
"Within 20%" = metrics_20
)
cat("\n--- Prediction Performance Report ---\n")
print(round(performance_report, 6))
# Calculate simple accuracy percentages for verification
cat("\n--- Simple Accuracy Check ---\n")
cat("Accuracy within 10%:", mean(abs(actuals - preds) <= 0.10 * actuals), "\n")
cat("Accuracy within 15%:", mean(abs(actuals - preds) <= 0.15 * actuals), "\n")
cat("Accuracy within 20%:", mean(abs(actuals - preds) <= 0.20 * actuals), "\n")
