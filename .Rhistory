# Load the necessary library
library(randomForest)
# 1. Load the dataset
card_data <- read.csv("C:/Users/priya/OneDrive/Documents/STAT 574/hw1STAT574S26/DATA SETS/card_transdata.csv")
# 2. Data Partitioning (80% Train, 20% Test)
set.seed(447558)
indexing <- sample(c(TRUE, FALSE), nrow(card_data), replace = TRUE, prob = c(0.8, 0.2))
train_set <- card_data[indexing, ]
